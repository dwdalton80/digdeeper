rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatars — user can only read/write their own
    match /avatars/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024  // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Group covers — any signed-in user can read; only group members can write
    // (member check is done client-side; server enforces auth + size + type)
    match /groupCovers/{groupId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10 MB max
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
